{
  "name": "alfanjauhari.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:content && pnpm build:og && cross-env NODE_ENV=development tsx watch -r dotenv/config scripts/serve.ts",
    "start": "cross-env NODE_ENV=production node -r dotenv/config dist/scripts/serve.js",
    "build": "cross-env SKIP_RATE_LIMIT=1 pnpm build:content && pnpm build:og && vite build && pnpm upload",
    "build:content": "content-collections build",
    "build:og": "tsx ./scripts/generate-og.tsx",
    "build:scripts": "tsx ./build-scripts.ts",
    "upload": "tsx ./scripts/upload-assets.ts",
    "serve": "vite preview",
    "test": "vitest run",
    "format": "biome format --write .",
    "lint": "biome lint",
    "check": "biome check",
    "db:init": "pnpm build:scripts && node scripts/db-init.cjs",
    "db:kit": "drizzle-kit",
    "typecheck": "tsc -p ./tsconfig.json",
    "playwright:install": "playwright install --with-deps chromium",
    "postinstall": "pnpm playwright:install && pnpm lefthook install"
  },
